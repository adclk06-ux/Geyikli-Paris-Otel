---
const categories = [
  { label: 'Odalar', span: 'large' },
  { label: 'Ortak Alanlar', span: 'small' },
  { label: 'Kahvaltı', span: 'small' },
  { label: 'Çevre', span: 'small' },
  { label: 'Çevre', span: 'small' },
];
---

<section class="section gallery-preview">
  <div class="container">
    <div class="gallery-header">
      <span class="eyebrow">Galeri</span>
      <h2 class="section-title">Geyikli Paris'ten Kareler</h2>
      <p class="section-subtitle">Konaklama deneyiminizden önce mekanımızı keşfedin.</p>
    </div>
    <div class="gallery-masonry">
      <div class="gallery-item large">
        <div class="gallery-placeholder">
          <span>Odalar</span>
        </div>
      </div>
      <div class="gallery-item">
        <div class="gallery-placeholder">
          <span>Ortak Alanlar</span>
        </div>
      </div>
      <div class="gallery-item">
        <div class="gallery-placeholder">
          <span>Kahvaltı</span>
        </div>
      </div>
      <div class="gallery-item">
        <div class="gallery-placeholder">
          <span>Çevre</span>
        </div>
      </div>
      <div class="gallery-item">
        <div class="gallery-placeholder">
          <span>Çevre</span>
        </div>
      </div>
    </div>
    <div class="gallery-cta">
      <a href="/galeri" class="btn btn-outline">Tüm Galeriyi Gör</a>
    </div>
  </div>
</section>

<style>
  .gallery-header { text-align: center; margin-bottom: 3rem; }
  .eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }
  .gallery-masonry {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 1rem;
    height: 520px;
  }
  .gallery-item {
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
  }
  .gallery-item.large {
    grid-row: 1 / -1;
  }
  .gallery-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #1e2823 0%, #141a17 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: transform 0.6s ease;
  }
  .gallery-item:hover .gallery-placeholder { transform: scale(1.04); }
  .gallery-placeholder::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15,20,18,0.5) 0%, transparent 60%);
  }
  .gallery-placeholder span {
    position: relative;
    z-index: 2;
  }
  .gallery-cta {
    text-align: center;
    margin-top: 2.5rem;
  }
  @media (max-width: 768px) {
    .gallery-masonry {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 200px 150px 150px;
      height: auto;
    }
    .gallery-item.large { grid-row: auto; grid-column: 1 / -1; }
  }
</style>
