---
const galleryItems = [
  {
    src: '/images/hotel/geyikli-paris-otel-oda-cift-kisilik-1.jpg',
    alt: 'Geyikli Paris Otel çift kişilik oda',
    label: 'Odalar',
    span: 'large',
  },
  {
    src: '/images/hotel/geyikli-paris-otel-dis-cephe-2.jpg',
    alt: 'Geyikli Paris Otel dış cephe görünümü',
    label: 'Dış Cephe',
    span: 'small',
  },
  {
    src: '/images/hotel/geyikli-paris-otel-oda-balkon-1.jpg',
    alt: 'Geyikli Paris Otel balkonlu oda görünümü',
    label: 'Balkon ve Manzara',
    span: 'small',
  },
  {
    src: '/images/hotel/geyikli-paris-otel-elektrikli-arac-sarj-istasyonu-1.jpg',
    alt: 'Geyikli Paris Otel elektrikli araç şarj istasyonu',
    label: 'Elektrikli Şarj İstasyonu',
    span: 'small',
  },
  {
    src: '/images/hotel/geyikli-paris-otel-bahce-1.jpg',
    alt: 'Geyikli Paris Otel bahçe alanı',
    label: 'Bahçe',
    span: 'small',
  },
];
---

<section class="section gallery-preview">
  <div class="container">
    <div class="gallery-header">
      <span class="eyebrow">Galeri</span>
      <h2 class="section-title">Geyikli Paris'ten Kareler</h2>
      <p class="section-subtitle">Konaklama deneyiminizden önce mekanımızı keşfedin.</p>
    </div>
    <div class="gallery-masonry">
      {galleryItems.map((item) => (
        <div class={`gallery-item ${item.span}`}>
          <img
            src={item.src}
            alt={item.alt}
            loading="lazy"
            decoding="async"
          />
          <div class="gallery-item-overlay">
            <span>{item.label}</span>
          </div>
        </div>
      ))}
    </div>
    <div class="gallery-cta">
      <a href="/galeri" class="btn btn-outline">Tüm Galeriyi Gör</a>
    </div>
  </div>
</section>

<style>
  .gallery-header { text-align: center; margin-bottom: 3rem; }
  .eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }
  .gallery-masonry {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 1rem;
    height: 520px;
  }
  .gallery-item {
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
  }
  .gallery-item.large {
    grid-row: 1 / -1;
  }
  .gallery-item img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.6s ease;
  }
  .gallery-item:hover img { transform: scale(1.04); }
  .gallery-item-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(to top, rgba(15,20,18,0.5) 0%, transparent 60%);
    transition: background 0.4s ease;
  }
  .gallery-item:hover .gallery-item-overlay {
    background: linear-gradient(to top, rgba(15,20,18,0.7) 0%, transparent 70%);
  }
  .gallery-item-overlay span {
    position: relative;
    z-index: 2;
    color: var(--color-muted);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(247, 239, 227, 0.2);
    border-radius: 999px;
    background: rgba(15, 20, 18, 0.5);
  }
  .gallery-cta {
    text-align: center;
    margin-top: 2.5rem;
  }
  @media (max-width: 768px) {
    .gallery-masonry {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 200px 150px 150px;
      height: auto;
    }
    .gallery-item.large { grid-row: auto; grid-column: 1 / -1; }
  }
</style>
