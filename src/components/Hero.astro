---
import { hotelConfig } from '../config/hotel';
---

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="container hero-inner">
    <span class="hero-eyebrow">Geyikli &bull; Çanakkale</span>
    <h1 class="hero-title">Geyikli Paris'te Zarif ve Huzurlu Konaklama</h1>
    <p class="hero-subtitle">Geyikli'nin sakin atmosferinde, konforu ve sıcak misafirperverliği bir araya getiren özel bir konaklama deneyimi.</p>
    <div class="hero-actions">
      <a href={`tel:${hotelConfig.phone}`} class="btn btn-primary">Rezervasyon İçin Arayın</a>
      <a href={`https://wa.me/${hotelConfig.whatsapp}`} target="_blank" rel="noopener noreferrer" class="btn btn-outline">WhatsApp'tan Yazın</a>
      <a href="/odalar" class="btn btn-outline">Odaları İncele</a>
    </div>
    <div class="hero-trust">
      <span>Telefonla Rezervasyon</span>
      <span class="dot"></span>
      <span>Sıcak Karşılama</span>
      <span class="dot"></span>
      <span>Huzurlu Konaklama</span>
    </div>
  </div>
  <div class="hero-scroll">
    <span class="scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    padding-top: 5rem;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #1a2520 0%, #0d1110 50%, #111815 100%);
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.4;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.6) 100%);
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 800px;
  }
  .hero-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1.25rem;
    border: 1px solid rgba(201, 164, 92, 0.35);
    padding: 0.4rem 1rem;
    border-radius: 999px;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: 3.8rem;
    font-weight: 500;
    color: var(--color-ivory);
    line-height: 1.1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }
  .hero-subtitle {
    font-size: 1.15rem;
    font-weight: 300;
    color: var(--color-muted);
    max-width: 560px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
    margin-bottom: 2.5rem;
  }
  .hero-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .hero-trust .dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--color-gold);
    opacity: 0.6;
  }
  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }
  .scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--color-gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.3); }
  }
  @media (max-width: 768px) {
    .hero { min-height: 100svh; padding-top: 6rem; }
    .hero-title { font-size: 2.4rem; }
    .hero-subtitle { font-size: 1rem; padding: 0 1rem; }
    .hero-actions { flex-direction: column; align-items: center; }
    .hero-actions .btn { width: 100%; max-width: 300px; }
    .hero-trust { gap: 0.4rem 0.8rem; }
    .hero-trust .dot { display: none; }
  }
</style>
