---
import RoomCard from './RoomCard.astro';

const rooms = [
  {
    title: 'Çift Kişilik Oda',
    description: 'Çift kişilik konaklama için uygun, temiz ve huzurlu oda.',
    capacity: '2 Kişi',
    bed: 'Çift Kişilik',
    features: ['Klima', 'Wi-Fi', 'TV'],
    image: '/images/hotel/geyikli-paris-otel-oda-cift-kisilik-1.jpg',
    imageAlt: 'Geyikli Paris Otel çift kişilik oda',
  },
  {
    title: 'Balkonlu Oda',
    description: 'Balkonlu oda seçeneği ile ferah ve aydınlık konaklama deneyimi.',
    capacity: '2 Kişi',
    bed: 'Çift Kişilik',
    features: ['Klima', 'Wi-Fi', 'TV', 'Balkon'],
    image: '/images/hotel/geyikli-paris-otel-oda-balkon-1.jpg',
    imageAlt: 'Geyikli Paris Otel balkonlu oda görünümü',
  },
  {
    title: 'Aile Odası',
    description: 'Aile konaklamaları için uygun oda seçeneği.',
    capacity: '4 Kişi',
    bed: 'Çift + Tek',
    features: ['Klima', 'Wi-Fi', 'TV', 'Balkon'],
    image: '/images/hotel/geyikli-paris-otel-aile-odasi-1.jpg',
    imageAlt: 'Geyikli Paris Otel aile odası',
  },
];
---

<section class="section rooms">
  <div class="container">
    <div class="rooms-header">
      <span class="eyebrow">Odalarımız</span>
      <h2 class="section-title">Her Misafire Uygun Konforlu Odalar</h2>
      <p class="section-subtitle">Geyikli Paris'te temiz ve huzurlu bir konaklama deneyimi sizi bekliyor.</p>
    </div>
    <div class="rooms-grid">
      {rooms.map((room) => <RoomCard {...room} />)}
    </div>
  </div>
</section>

<style>
  .rooms { background: var(--color-surface); }
  .rooms-header { text-align: center; margin-bottom: 3rem; }
  .eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }
  .rooms-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 768px) {
    .rooms-grid { grid-template-columns: 1fr; }
  }
</style>
