---
import RoomCard from './RoomCard.astro';

const rooms = [
  {
    title: 'Standart Oda',
    description: 'Rahat ve huzurlu bir konaklama için ideal seçim. Temiz, ferah ve özenle hazırlanmış.',
    capacity: '2 Kişi',
    bed: 'Çift Kişilik',
    features: ['Klima', 'Wi-Fi', 'TV'],
  },
  {
    title: 'Deluxe Oda',
    description: 'Biraz daha fazla alan ve konfor arayanlar için geniş ve şık dekore edilmiş oda.',
    capacity: '2 Kişi',
    bed: 'King Size',
    features: ['Klima', 'Wi-Fi', 'TV', 'Minibar'],
  },
  {
    title: 'Aile Odası',
    description: 'Aileler ve kalabalık gruplar için geniş, konforlu ve pratik konaklama seçeneği.',
    capacity: '4 Kişi',
    bed: 'Çift + Tek',
    features: ['Klima', 'Wi-Fi', 'TV', 'Balkon'],
  },
];
---

<section class="section rooms">
  <div class="container">
    <div class="rooms-header">
      <span class="eyebrow">Odalarımız</span>
      <h2 class="section-title">Her Misafire Uygun Konforlu Odalar</h2>
      <p class="section-subtitle">Geyikli Paris'te temiz ve huzurlu bir konaklama deneyimi sizi bekliyor.</p>
    </div>
    <div class="rooms-grid">
      {rooms.map((room) => <RoomCard {...room} />)}
    </div>
  </div>
</section>

<style>
  .rooms { background: var(--color-surface); }
  .rooms-header { text-align: center; margin-bottom: 3rem; }
  .eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }
  .rooms-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 768px) {
    .rooms-grid { grid-template-columns: 1fr; }
  }
</style>
