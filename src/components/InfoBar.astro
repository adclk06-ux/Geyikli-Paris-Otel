---
import { hotelConfig } from '../config/hotel';
---

<div class="info-bar-wrapper">
  <div class="container">
    <div class="info-bar">
      <div class="info-item">
        <span class="info-label">Konum</span>
        <span class="info-value">{hotelConfig.location}</span>
      </div>
      <div class="info-divider"></div>
      <div class="info-item">
        <span class="info-label">Rezervasyon</span>
        <span class="info-value">Telefon / WhatsApp</span>
      </div>
      <div class="info-divider"></div>
      <div class="info-item">
        <span class="info-label">Odalar</span>
        <span class="info-value">Standart, Deluxe, Aile</span>
      </div>
      <div class="info-divider"></div>
      <div class="info-item">
        <span class="info-label">Deneyim</span>
        <span class="info-value">Temiz, Sakin, Güvenilir</span>
      </div>
    </div>
  </div>
</div>

<style>
  .info-bar-wrapper {
    position: relative;
    z-index: 10;
    margin-top: -3.5rem;
    padding: 0 1rem;
  }
  .info-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(23, 29, 26, 0.85);
    backdrop-filter: blur(16px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem 2.5rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .info-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    text-align: center;
    flex: 1;
  }
  .info-label {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .info-value {
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--color-ivory);
  }
  .info-divider {
    width: 1px;
    height: 2rem;
    background: var(--color-border);
  }
  @media (max-width: 640px) {
    .info-bar {
      flex-wrap: wrap;
      gap: 1rem;
      padding: 1.25rem;
    }
    .info-item {
      flex: 1 1 45%;
      text-align: left;
    }
    .info-divider { display: none; }
  }
</style>
