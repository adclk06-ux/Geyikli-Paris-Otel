---
export interface Props {
  title: string;
  description: string;
  capacity?: string;
  bed?: string;
  features?: string[];
  image?: string;
  imageAlt?: string;
}

const { title, description, capacity, bed, features = [], image, imageAlt } = Astro.props;
---

<div class="room-card card">
  <div class="room-image">
    {image ? (
      <img
        src={image}
        alt={imageAlt || title}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="room-image-placeholder">
        <span>{title}</span>
      </div>
    )}
    <div class="room-image-overlay"></div>
  </div>
  <div class="room-body">
    <div class="room-meta">
      {capacity && <span class="meta-item">{capacity}</span>}
      {bed && <span class="meta-dot"></span>}
      {bed && <span class="meta-item">{bed}</span>}
    </div>
    <h3 class="room-title">{title}</h3>
    <p class="room-desc">{description}</p>
    {features.length > 0 && (
      <ul class="room-features">
        {features.map((f) => <li>{f}</li>)}
      </ul>
    )}
    <div class="room-actions">
      <a href="/odalar" class="room-link">Odayı İncele</a>
      <a href="tel:HOTEL_PHONE" class="room-link gold">Müsaitlik İçin Arayın</a>
    </div>
  </div>
</div>

<style>
  .room-card { transition: transform 0.4s ease, box-shadow 0.4s ease; }
  .room-card:hover { transform: translateY(-8px); box-shadow: var(--shadow); }
  .room-image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }
  .room-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.6s ease;
  }
  .room-card:hover .room-image img { transform: scale(1.05); }
  .room-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(160deg, #1e2823 0%, #141a17 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: transform 0.6s ease;
  }
  .room-card:hover .room-image-placeholder { transform: scale(1.05); }
  .room-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15,20,18,0.6) 0%, transparent 50%);
    pointer-events: none;
  }
  .room-body { padding: 1.5rem; }
  .room-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }
  .meta-item {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .meta-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--color-gold);
    opacity: 0.5;
  }
  .room-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--color-ivory);
    margin-bottom: 0.5rem;
  }
  .room-desc {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.65;
    margin-bottom: 1rem;
  }
  .room-features {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .room-features li {
    background: rgba(246, 240, 230, 0.06);
    padding: 0.35rem 0.8rem;
    border-radius: 999px;
    font-size: 0.78rem;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
  }
  .room-actions {
    display: flex;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }
  .room-link {
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    transition: color 0.2s;
  }
  .room-link:hover { color: var(--color-ivory); }
  .room-link.gold { color: var(--color-gold); }
  .room-link.gold:hover { color: var(--color-gold-soft); }
</style>
