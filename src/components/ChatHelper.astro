---
import { hotelConfig } from '../config/hotel';

const quickReplies = [
  { label: 'Oda müsaitliği sormak istiyorum', href: `https://wa.me/${hotelConfig.whatsapp}` },
  { label: 'Oda seçeneklerini görmek istiyorum', href: '/odalar' },
  { label: 'Konum bilgisi almak istiyorum', href: '/konum' },
  { label: 'Telefonla rezervasyon yapmak istiyorum', href: `tel:${hotelConfig.phone}` },
];
---

<div class="chat-helper" id="chatHelper">
  <button class="chat-toggle" id="chatToggle" aria-label="Sohbet">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
      <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H5.17L4 17.17V4h16v12z"/>
      <path d="M7 9h10v2H7zm0-3h10v2H7z"/>
    </svg>
  </button>
  <div class="chat-panel" id="chatPanel">
    <div class="chat-header">
      <div class="chat-avatar">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
        </svg>
      </div>
      <div class="chat-meta">
        <span class="chat-title">{hotelConfig.chatTitle}</span>
        <span class="chat-status">Çevrimiçi</span>
      </div>
      <button class="chat-close" id="chatClose" aria-label="Kapat">&times;</button>
    </div>
    <div class="chat-body">
      <div class="chat-bubble">
        <p>{hotelConfig.chatMessage}</p>
      </div>
      <div class="chat-replies">
        {quickReplies.map((reply) => (
          <a href={reply.href} target={reply.href.startsWith('http') ? '_blank' : undefined} rel={reply.href.startsWith('http') ? 'noopener noreferrer' : undefined} class="chat-reply">
            {reply.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .chat-helper { position: fixed; bottom: 1.5rem; left: 1.5rem; z-index: 200; }
  .chat-toggle {
    width: 52px; height: 52px; border-radius: 50%;
    background: var(--color-surface);
    color: var(--color-gold);
    border: 1px solid var(--color-border-strong);
    display: flex; align-items: center; justify-content: center;
    box-shadow: var(--shadow-soft);
    transition: all 0.3s ease;
  }
  .chat-toggle:hover {
    transform: scale(1.1) translateY(-2px);
    border-color: var(--color-gold);
    background: var(--color-surface-raised);
  }
  .chat-panel {
    position: absolute; bottom: 64px; left: 0;
    width: 300px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    display: none;
    overflow: hidden;
  }
  .chat-panel.open { display: block; }
  .chat-header {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  .chat-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(201, 164, 92, 0.15);
    color: var(--color-gold);
    display: flex; align-items: center; justify-content: center;
  }
  .chat-meta { flex: 1; }
  .chat-title { display: block; font-weight: 500; font-size: 0.9rem; color: var(--color-ivory); }
  .chat-status { font-size: 0.75rem; color: var(--color-gold); }
  .chat-close { color: var(--color-muted); font-size: 1.3rem; line-height: 1; transition: color 0.2s; }
  .chat-close:hover { color: var(--color-ivory); }
  .chat-body { padding: 1rem; }
  .chat-bubble {
    background: var(--color-surface-raised);
    padding: 0.85rem 1rem;
    border-radius: var(--radius);
    margin-bottom: 1rem;
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.6;
  }
  .chat-replies {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .chat-reply {
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.82rem;
    color: var(--color-muted);
    transition: all 0.2s;
    text-align: left;
  }
  .chat-reply:hover {
    border-color: var(--color-gold);
    color: var(--color-ivory);
    background: rgba(201, 164, 92, 0.05);
  }
</style>

<script is:inline>
  (function() {
    const toggle = document.getElementById('chatToggle');
    const panel = document.getElementById('chatPanel');
    const close = document.getElementById('chatClose');
    toggle?.addEventListener('click', () => panel?.classList.toggle('open'));
    close?.addEventListener('click', () => panel?.classList.remove('open'));
  })();
</script>
