---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import ChatHelper from '../components/ChatHelper.astro';
import { hotelConfig } from '../config/hotel';

export interface Props {
  title?: string;
  description?: string;
  isHome?: boolean;
}

const { title, description, isHome = false } = Astro.props;
const pageTitle = title ? `${title} | ${hotelConfig.hotelName}` : hotelConfig.hotelName;
const pageDesc = description || hotelConfig.metaDescription;
---

<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <meta name="keywords" content={hotelConfig.keywords.join(', ')} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <Header isHome={isHome} />
  <main>
    <slot />
  </main>
  <Footer />
  <FloatingWhatsApp />
  <ChatHelper />
</body>
</html>
