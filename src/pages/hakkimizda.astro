---
import Layout from '../layouts/Layout.astro';
import FinalCTA from '../components/FinalCTA.astro';
---

<Layout title="Hakkımızda">
  <section class="page-hero">
    <div class="container">
      <span class="page-eyebrow">Hakkımızda</span>
      <h1 class="page-title">Geyikli Paris'in Hikayesi</h1>
      <p class="page-subtitle">Çanakkale'nin huzurlu köşesi Geyikli'de sıcak ve güvenilir bir konaklama deneyimi.</p>
    </div>
  </section>
  <section class="section">
    <div class="container about-grid">
      <div class="about-image">
        <div class="image-frame">
          <img
            src="/images/hotel/dis-cephe-2.jpg"
            alt="Geyikli Paris Otel dış cephe ve bahçe görünümü"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
      <div class="about-text">
        <h2 class="about-heading">Sıcak, Güvenilir ve Konforlu Bir Konaklama</h2>
        <p>
          Geyikli Paris, Geyikli, Çanakkale'de misafirlerine sıcak ve güvenilir bir konaklama deneyimi sunmayı ilke edinmiş bir oteldir. Temizlik, konfor ve misafir memnuniyeti önceliğimizdir.
        </p>
        <p>
          Çanakkale'nin incisi Geyikli'de konaklamak isteyen ziyaretçiler için rahat odalar ve samimi bir atmosfer hazırladık. Bozcaada'ya yakın konaklama arayanlar için de ideal bir durak noktasıyız.
        </p>
        <p>
          Telefonla rezervasyon veya WhatsApp üzerinden bize ulaşarak oda müsaitliği hakkında bilgi alabilirsiniz.
        </p>
      </div>
    </div>
  </section>
  <FinalCTA />
</Layout>

<style>
  .page-hero {
    padding: 10rem 0 5rem;
    text-align: center;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-surface) 100%);
    border-bottom: 1px solid var(--color-border);
  }
  .page-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: 2.8rem;
    font-weight: 500;
    color: var(--color-ivory);
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }
  .page-subtitle {
    font-size: 1.05rem;
    color: var(--color-muted);
    max-width: 520px;
    margin: 0 auto;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .about-image { order: 2; }
  .about-text { order: 1; max-width: 520px; }
  .about-heading {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 500;
    color: var(--color-ivory);
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }
  .about-text p {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.85;
    margin-bottom: 1.25rem;
  }
  .image-frame {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .image-frame::before {
    content: '';
    position: absolute;
    inset: -12px;
    border: 1px solid rgba(201, 164, 92, 0.2);
    border-radius: calc(var(--radius-lg) + 12px);
    z-index: -1;
  }
  .image-frame img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center;
  }
  @media (max-width: 768px) {
    .page-title { font-size: 2.2rem; }
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-image { order: -1; }
  }
</style>
