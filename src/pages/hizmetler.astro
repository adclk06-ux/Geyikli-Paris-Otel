---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import FinalCTA from '../components/FinalCTA.astro';

const groups = [
  {
    name: 'Konfor',
    items: [
      { title: 'Ücretsiz Wi-Fi', description: 'Tüm alanlarda hızlı internet erişimi.' },
      { title: 'Klima', description: 'Her odada ferahlatıcı klima sistemi.' },
      { title: 'Kahvaltı', description: 'Güne lezzetli bir kahvaltıyla başlayın.' },
      { title: 'Aile Odaları', description: 'Ailelere özel geniş konaklama seçenekleri.' },
      { title: 'Elektrikli Araç Şarj İstasyonu', description: 'Elektrikli araçla gelen misafirlerimiz için otel alanında şarj imkânı sunulur.' },
    ],
  },
  {
    name: 'İletişim',
    items: [
      { title: '7/24 Resepsiyon', description: 'Her an yardım alabileceğiniz resepsiyon.' },
      { title: 'Hızlı İletişim', description: 'Telefon ve WhatsApp ile anında yanıt.' },
    ],
  },
  {
    name: 'Temizlik',
    items: [
      { title: 'Günlük Temizlik', description: 'Odalar düzenli olarak temizlenir.' },
      { title: 'Güvenli Konaklama', description: 'Güven veren, sakin bir ortam.' },
    ],
  },
  {
    name: 'Ulaşım & Konum',
    items: [
      { title: 'Otopark', description: 'Konuklarımız için araç park olanağı.' },
      { title: 'Merkezi Konum', description: 'Geyikli merkezinde pratik konum.' },
    ],
  },
];
---

<Layout title="Hizmetler">
  <section class="page-hero">
    <div class="container">
      <span class="page-eyebrow">Hizmetlerimiz</span>
      <h1 class="page-title">Konforlu Bir Konaklama İçin Sunduklarımız</h1>
      <p class="page-subtitle">Geyikli Paris'te misafirlerimizin ihtiyaçlarını ön planda tutuyoruz.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="featured-service">
        <div class="featured-image">
          <img
            src="/images/hotel/sarj-istasyonu-1.jpg"
            alt="Geyikli Paris Otel elektrikli araç şarj istasyonu"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="featured-text">
          <span class="featured-eyebrow">Öne Çıkan Olanak</span>
          <h2 class="featured-title">Elektrikli Araç Şarj İstasyonu</h2>
          <p class="featured-desc">
            Elektrikli araçla gelen misafirlerimiz için otel alanında şarj imkânı sunulur.
          </p>
        </div>
      </div>
      {groups.map((group) => (
        <div class="group">
          <h2 class="group-name">{group.name}</h2>
          <div class="group-grid">
            {group.items.map((item) => <ServiceCard {...item} />)}
          </div>
        </div>
      ))}
    </div>
  </section>
  <FinalCTA />
</Layout>

<style>
  .page-hero {
    padding: 10rem 0 5rem;
    text-align: center;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-surface) 100%);
    border-bottom: 1px solid var(--color-border);
  }
  .page-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: 2.8rem;
    font-weight: 500;
    color: var(--color-ivory);
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }
  .page-subtitle {
    font-size: 1.05rem;
    color: var(--color-muted);
    max-width: 520px;
    margin: 0 auto;
  }
  .group { margin-bottom: 3.5rem; }
  .group-name {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--color-ivory);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  .group-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .featured-service {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    margin-bottom: 5rem;
    padding: 2.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .featured-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .featured-image img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: center;
  }
  .featured-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }
  .featured-title {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 500;
    color: var(--color-ivory);
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .featured-desc {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.75;
  }
  @media (max-width: 768px) {
    .page-title { font-size: 2.2rem; }
    .group-grid { grid-template-columns: repeat(2, 1fr); }
    .featured-service {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 1.5rem;
    }
    .featured-image { order: -1; }
  }
  @media (max-width: 480px) {
    .group-grid { grid-template-columns: 1fr; }
  }
</style>
