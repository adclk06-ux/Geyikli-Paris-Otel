---
import Layout from '../layouts/Layout.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { hotelConfig } from '../config/hotel';
---

<Layout title="İletişim">
  <section class="page-hero">
    <div class="container">
      <span class="page-eyebrow">İletişim</span>
      <h1 class="page-title">Bizimle İletişime Geçin</h1>
      <p class="page-subtitle">Rezervasyon ve oda müsaitliği için telefon veya WhatsApp üzerinden ulaşabilirsiniz.</p>
    </div>
  </section>
  <section class="section">
    <div class="container contact-grid">
      <div class="contact-info">
        <div class="contact-card">
          <span class="contact-label">Adres</span>
          <span class="contact-value">{hotelConfig.address}</span>
        </div>
        <div class="contact-card">
          <span class="contact-label">Telefon</span>
          <span class="contact-value">{hotelConfig.phone}</span>
          <a href={`tel:${hotelConfig.phone}`} class="contact-action">Hemen Ara</a>
        </div>
        <div class="contact-card">
          <span class="contact-label">WhatsApp</span>
          <span class="contact-value">{hotelConfig.whatsapp}</span>
          <a href={`https://wa.me/${hotelConfig.whatsapp}`} target="_blank" rel="noopener noreferrer" class="contact-action">WhatsApp'tan Yaz</a>
        </div>
        <div class="contact-card">
          <span class="contact-label">E-posta</span>
          <span class="contact-value">{hotelConfig.email}</span>
        </div>
      </div>
      <div class="contact-policy">
        <h3 class="policy-title">Rezervasyon Politikası</h3>
        <p class="policy-text">
          Rezervasyon ve oda müsaitliği için lütfen telefon veya WhatsApp üzerinden iletişime geçin.
        </p>
        <p class="policy-text">
          Rezervasyonlarımız telefon ve WhatsApp üzerinden yapılmaktadır. Online rezervasyon, ödeme sistemi veya rezervasyon motoru bulunmamaktadır.
        </p>
        <div class="policy-actions">
          <a href={`tel:${hotelConfig.phone}`} class="btn btn-primary">Rezervasyon İçin Arayın</a>
          <a href={`https://wa.me/${hotelConfig.whatsapp}`} target="_blank" rel="noopener noreferrer" class="btn btn-outline">WhatsApp'tan Yazın</a>
        </div>
      </div>
    </div>
  </section>
  <FinalCTA />
</Layout>

<style>
  .page-hero {
    padding: 10rem 0 5rem;
    text-align: center;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-surface) 100%);
    border-bottom: 1px solid var(--color-border);
  }
  .page-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: 2.8rem;
    font-weight: 500;
    color: var(--color-ivory);
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }
  .page-subtitle {
    font-size: 1.05rem;
    color: var(--color-muted);
    max-width: 520px;
    margin: 0 auto;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: start;
  }
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .contact-card {
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    transition: border-color 0.3s;
  }
  .contact-card:hover { border-color: rgba(201, 164, 92, 0.25); }
  .contact-label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .contact-value {
    font-size: 0.95rem;
    color: var(--color-ivory);
    font-weight: 400;
  }
  .contact-action {
    font-size: 0.82rem;
    color: var(--color-gold);
    margin-top: 0.4rem;
    transition: color 0.2s;
  }
  .contact-action:hover { color: var(--color-gold-soft); }
  .contact-policy {
    padding: 2.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .policy-title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--color-ivory);
    margin-bottom: 1.25rem;
  }
  .policy-text {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.85;
    margin-bottom: 1.25rem;
  }
  .policy-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  @media (max-width: 768px) {
    .page-title { font-size: 2.2rem; }
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .policy-actions { flex-direction: column; }
    .policy-actions .btn { width: 100%; }
  }
</style>
