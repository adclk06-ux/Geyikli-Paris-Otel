---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';
import { hotelConfig } from '../config/hotel';
---

<Layout title="İletişim">
  <section class="section">
    <div class="container contact-content">
      <h1 class="section-title">İletişim</h1>
      <p>
        Rezervasyon ve oda müsaitliği için telefon veya WhatsApp üzerinden iletişime geçebilirsiniz.
      </p>
      <ul class="contact-list">
        <li><strong>Adres:</strong> {hotelConfig.address}</li>
        <li><strong>Telefon:</strong> {hotelConfig.phone}</li>
        <li><strong>WhatsApp:</strong> {hotelConfig.whatsapp}</li>
        <li><strong>E-posta:</strong> {hotelConfig.email}</li>
      </ul>
      <p class="contact-note">
        Rezervasyonlarımız telefon ve WhatsApp üzerinden yapılmaktadır. Online rezervasyon ve ödeme sistemi bulunmamaktadır.
      </p>
    </div>
  </section>
  <CTASection />
</Layout>

<style>
  .contact-content { max-width: 720px; }
  .contact-content p {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    line-height: 1.8;
  }
  .contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin: 1.5rem 0;
    padding: 1.25rem;
    background: var(--color-surface);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }
  .contact-list li {
    font-size: 0.95rem;
    color: var(--color-text);
  }
  .contact-note {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    padding: 1rem;
    background: var(--color-bg);
    border-radius: var(--radius);
  }
</style>
