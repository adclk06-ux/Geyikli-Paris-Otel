---
import Layout from '../layouts/Layout.astro';
import FinalCTA from '../components/FinalCTA.astro';

const categories = [
  {
    name: 'Dış Cephe',
    items: [
      { src: '/images/hotel/geyikli-paris-otel-dis-cephe-1.jpg', alt: 'Geyikli Paris Otel dış cephe görünümü' },
      { src: '/images/hotel/geyikli-paris-otel-dis-cephe-2.jpg', alt: 'Geyikli Paris Otel bahçe ve dış cephe' },
      { src: '/images/hotel/geyikli-paris-otel-dis-cephe-3.jpg', alt: 'Geyikli Paris Otel ön cephe' },
      { src: '/images/hotel/geyikli-paris-otel-giris-1.jpg', alt: 'Geyikli Paris Otel giriş alanı' },
    ],
  },
  {
    name: 'Odalar',
    items: [
      { src: '/images/hotel/geyikli-paris-otel-oda-cift-kisilik-1.jpg', alt: 'Geyikli Paris Otel çift kişilik oda' },
      { src: '/images/hotel/geyikli-paris-otel-oda-cift-kisilik-2.jpg', alt: 'Geyikli Paris Otel çift kişilik oda detay' },
      { src: '/images/hotel/geyikli-paris-otel-oda-cift-kisilik-3.jpg', alt: 'Geyikli Paris Otel çift kişilik oda iç mekan' },
      { src: '/images/hotel/geyikli-paris-otel-aile-odasi-1.jpg', alt: 'Geyikli Paris Otel aile odası' },
      { src: '/images/hotel/geyikli-paris-otel-aile-odasi-2.jpg', alt: 'Geyikli Paris Otel aile odası görünümü' },
    ],
  },
  {
    name: 'Balkon ve Manzara',
    items: [
      { src: '/images/hotel/geyikli-paris-otel-oda-balkon-1.jpg', alt: 'Geyikli Paris Otel balkonlu oda' },
      { src: '/images/hotel/geyikli-paris-otel-oda-balkon-2.jpg', alt: 'Geyikli Paris Otel balkon manzarası' },
    ],
  },
  {
    name: 'İç Alanlar',
    items: [
      { src: '/images/hotel/geyikli-paris-otel-ic-mekan-merdiven-1.jpg', alt: 'Geyikli Paris Otel iç merdiven alanı' },
      { src: '/images/hotel/geyikli-paris-otel-ic-mekan-merdiven-2.jpg', alt: 'Geyikli Paris Otel iç mekan detay' },
    ],
  },
  {
    name: 'Bahçe',
    items: [
      { src: '/images/hotel/geyikli-paris-otel-bahce-1.jpg', alt: 'Geyikli Paris Otel bahçe alanı' },
    ],
  },
  {
    name: 'Elektrikli Şarj İstasyonu',
    items: [
      { src: '/images/hotel/geyikli-paris-otel-elektrikli-arac-sarj-istasyonu-1.jpg', alt: 'Geyikli Paris Otel elektrikli araç şarj istasyonu' },
      { src: '/images/hotel/geyikli-paris-otel-elektrikli-arac-sarj-istasyonu-2.jpg', alt: 'Geyikli Paris Otel şarj ünitesi' },
      { src: '/images/hotel/geyikli-paris-otel-elektrikli-arac-sarj-istasyonu-3.jpg', alt: 'Geyikli Paris Otel elektrikli araç şarj detay' },
    ],
  },
];
---

<Layout title="Galeri">
  <section class="page-hero">
    <div class="container">
      <span class="page-eyebrow">Galeri</span>
      <h1 class="page-title">Geyikli Paris'ten Kareler</h1>
      <p class="page-subtitle">Konaklama deneyiminizden önce mekanımızı keşfedin.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      {categories.map((cat) => (
        <div class="category">
          <h2 class="category-name">{cat.name}</h2>
          <div class="category-grid">
            {cat.items.map((item) => (
              <div class="gallery-item">
                <img
                  src={item.src}
                  alt={item.alt}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
  <FinalCTA />
</Layout>

<style>
  .page-hero {
    padding: 10rem 0 5rem;
    text-align: center;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-surface) 100%);
    border-bottom: 1px solid var(--color-border);
  }
  .page-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: 2.8rem;
    font-weight: 500;
    color: var(--color-ivory);
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }
  .page-subtitle {
    font-size: 1.05rem;
    color: var(--color-muted);
    max-width: 520px;
    margin: 0 auto;
  }
  .category { margin-bottom: 4rem; }
  .category:last-child { margin-bottom: 0; }
  .category-name {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--color-ivory);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  .category-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .gallery-item {
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    aspect-ratio: 4 / 3;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.6s ease;
  }
  .gallery-item:hover img { transform: scale(1.04); }
  @media (max-width: 768px) {
    .page-title { font-size: 2.2rem; }
    .category-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
