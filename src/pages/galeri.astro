---
import Layout from '../layouts/Layout.astro';
import FinalCTA from '../components/FinalCTA.astro';

const galleryItems = [
  { label: 'Odalar', span: 'large' },
  { label: 'Ortak Alanlar', span: 'tall' },
  { label: 'Kahvaltı', span: 'normal' },
  { label: 'Çevre', span: 'normal' },
  { label: 'Ortak Alanlar', span: 'wide' },
  { label: 'Odalar', span: 'normal' },
  { label: 'Çevre', span: 'tall' },
  { label: 'Kahvaltı', span: 'normal' },
];
---

<Layout title="Galeri">
  <section class="page-hero">
    <div class="container">
      <span class="page-eyebrow">Galeri</span>
      <h1 class="page-title">Geyikli Paris'ten Kareler</h1>
      <p class="page-subtitle">Konaklama deneyiminizden önce mekanımızı keşfedin.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="gallery-masonry">
        {galleryItems.map((item, i) => (
          <div class={`gallery-item ${item.span}`}>
            <div class="gallery-placeholder">
              <span>{item.label}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <FinalCTA />
</Layout>

<style>
  .page-hero {
    padding: 10rem 0 5rem;
    text-align: center;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-surface) 100%);
    border-bottom: 1px solid var(--color-border);
  }
  .page-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: 2.8rem;
    font-weight: 500;
    color: var(--color-ivory);
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }
  .page-subtitle {
    font-size: 1.05rem;
    color: var(--color-muted);
    max-width: 520px;
    margin: 0 auto;
  }
  .gallery-masonry {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 220px;
    gap: 1rem;
  }
  .gallery-item {
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
  }
  .gallery-item.large {
    grid-column: span 2;
    grid-row: span 2;
  }
  .gallery-item.wide {
    grid-column: span 2;
  }
  .gallery-item.tall {
    grid-row: span 2;
  }
  .gallery-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #1e2823 0%, #141a17 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: transform 0.6s ease;
  }
  .gallery-item:hover .gallery-placeholder { transform: scale(1.04); }
  .gallery-placeholder::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15,20,18,0.5) 0%, transparent 60%);
  }
  .gallery-placeholder span { position: relative; z-index: 2; }
  @media (max-width: 768px) {
    .page-title { font-size: 2.2rem; }
    .gallery-masonry {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 160px;
    }
    .gallery-item.large { grid-column: span 2; grid-row: span 2; }
  }
</style>
